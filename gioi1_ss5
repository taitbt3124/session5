CREATE SCHEMA kha3;

CREATE TABLE kha3.customers (
    customer_id INT PRIMARY KEY,
    customer_name VARCHAR(100),
    city VARCHAR(100)
);

CREATE TABLE kha3.orders (
     order_id INT PRIMARY KEY,
     customer_id INT,
     order_date DATE,
     total_price DECIMAL(10, 2),
     FOREIGN KEY (customer_id) REFERENCES kha3.customers(customer_id)
);

CREATE TABLE kha3.order_items (
      item_id INT PRIMARY KEY,
      order_id INT,
      product_id INT,
      quantity INT,
      price DECIMAL(10, 2),
      FOREIGN KEY (order_id) REFERENCES kha3.orders(order_id)
);

