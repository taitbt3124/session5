select o.customer_id ,sum(total_price) total_revenue, count(item_id) order_count
    from kha3.order_items inner join kha3.orders o on o.order_id = order_items.order_id
group by customer_id having sum(total_price) >2000;


SELECT customer_id, SUM(total_price) AS total_revenue
FROM kha3.orders
GROUP BY customer_id
HAVING SUM(total_price) > (
    -- Subquery: Tính doanh thu trung bình tính trên mỗi khách hàng
    SELECT AVG(customer_total)
    FROM (
             SELECT SUM(total_price) AS customer_total
             FROM kha3.orders
             GROUP BY customer_id
         ) AS sub_table
);


SELECT c.city, SUM(o.total_price) AS city_revenue
FROM kha3.customers c
         JOIN kha3.orders o ON c.customer_id = o.customer_id
GROUP BY c.city
HAVING SUM(o.total_price) = (
    SELECT MAX(city_total)
    FROM (
             SELECT SUM(total_price) AS city_total
             FROM kha3.customers c2
                      JOIN kha3.orders o2 ON c2.customer_id = o2.customer_id
             GROUP BY c2.city
         ) sub
);

select customer_name,city, sum(total_price) total_spend, sum(oi.quantity) total_quantity
    from kha3.orders
        inner join kha3.customers c on c.customer_id = orders.customer_id
        inner join kha3.order_items oi on orders.order_id = oi.order_id
group by customer_name,city

